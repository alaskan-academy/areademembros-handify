# Supabase — preencher com o projeto da Handify
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui   # NUNCA expor no client

# Payt — HMAC secret para validação de webhooks
PAYT_WEBHOOK_SECRET=seu-secret-payt-aqui

# Panda Video
PANDA_VIDEO_API_KEY=sua-api-key-panda-aqui

# Resend (e-mail transacional)
RESEND_API_KEY=re_sua-key-aqui

# URL pública da aplicação (sem barra no final)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Chave para criptografar CPF no banco (32 bytes em hex)
# Gerar com: openssl rand -hex 32
CERTIFICATE_ENCRYPTION_KEY=sua-chave-32-bytes-hex-aqui
